<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/student_register"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@android:color/white">

        <!-- 顶部栏 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@color/blue"
            android:gravity="center_vertical"
            android:paddingHorizontal="16dp">

            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="返回"
                android:src="@android:drawable/ic_menu_revert"
                app:tint="@android:color/white" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="学生注册"
                android:textColor="@android:color/white"
                android:textSize="20sp"
                android:gravity="center"
                android:layout_marginEnd="40dp" />
        </LinearLayout>

        <!-- 上半部分：单独注册 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="30dp"
            android:padding="16dp"
            android:background="@drawable/card_background">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="单独注册"
                android:textSize="18sp"
                android:textColor="@color/blue"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"
                android:drawableStart="@drawable/ic_person_24"
                android:drawablePadding="8dp"
                android:drawableTint="@color/blue" />



            <!-- 输入行：账号 + 班级 + 按钮 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- 左侧：账号输入框 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="3"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="学生账号"
                        android:textSize="14sp"
                        android:textColor="@color/dark_gray"
                        android:layout_marginBottom="4dp" />

                    <EditText
                        android:id="@+id/et_single_username"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:hint="输入学生账号"
                        android:inputType="text"
                        android:maxLines="1"
                        android:singleLine="true"
                        android:background="@drawable/edit_text_border"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:textSize="14sp"
                        android:textColor="@color/black" />
                </LinearLayout>

                <!-- 中间：班级选择器 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="2"
                    android:orientation="vertical"
                    android:layout_marginEnd="8dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="班级"
                        android:textSize="14sp"
                        android:textColor="@color/dark_gray"
                        android:layout_marginBottom="4dp" />

                    <Spinner
                        android:id="@+id/spinner_single_class"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/spinner_background"
                        android:textSize="14sp" />
                </LinearLayout>

                <!-- 右侧：注册按钮 -->
                <Button
                    android:id="@+id/btn_single_register"
                    android:layout_width="0dp"
                    android:layout_height="48dp"
                    android:layout_weight="1.5"
                    android:text="注册"
                    android:background="@drawable/button_green"
                    android:textColor="@color/white"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:layout_marginTop="14dp" />
            </LinearLayout>

            <!-- 说明文字 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="密码默认为账号"
                android:textSize="13sp"
                android:textColor="@color/gray"
                android:layout_marginTop="8dp"
                android:drawableStart="@drawable/ic_info_24"
                android:drawablePadding="4dp" />
        </LinearLayout>

        <!-- 下半部分：批量注册 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="@drawable/card_background">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="批量注册"
                android:textSize="18sp"
                android:textColor="@color/blue"
                android:textStyle="bold"
                android:layout_marginBottom="12dp"
                android:drawableStart="@drawable/ic_group_24"
                android:drawablePadding="8dp"
                android:drawableTint="@color/blue" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="批量注册多个学生账号，建议使用学号"
                android:textSize="14sp"
                android:textColor="@color/gray"
                android:layout_marginBottom="20dp" />

            <!-- 数字范围输入 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="16dp">

                <!-- 起始数字 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginEnd="12dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="起始数字"
                        android:textSize="14sp"
                        android:textColor="@color/dark_gray"
                        android:layout_marginBottom="4dp" />

                    <EditText
                        android:id="@+id/et_batch_start"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:hint="例如: 1001"
                        android:inputType="number"
                        android:maxLines="1"
                        android:singleLine="true"
                        android:background="@drawable/edit_text_border"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:textSize="14sp"
                        android:textColor="@color/black" />
                </LinearLayout>

                <!-- 结束数字 -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="结束数字"
                        android:textSize="14sp"
                        android:textColor="@color/dark_gray"
                        android:layout_marginBottom="4dp" />

                    <EditText
                        android:id="@+id/et_batch_end"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:hint="例如: 1050"
                        android:inputType="number"
                        android:maxLines="1"
                        android:singleLine="true"
                        android:background="@drawable/edit_text_border"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:textSize="14sp"
                        android:textColor="@color/black" />
                </LinearLayout>
            </LinearLayout>



            <!-- 班级选择 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="班级"
                    android:textSize="14sp"
                    android:textColor="@color/dark_gray"
                    android:layout_marginBottom="4dp" />

                <Spinner
                    android:id="@+id/spinner_batch_class"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/spinner_background"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- 批量范围提示 -->
            <TextView
                android:id="@+id/tv_batch_range"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="请输入起始和结束数字"
                android:textSize="13sp"
                android:textColor="@color/gray"
                android:layout_marginBottom="12dp" />

            <!-- 批量注册按钮 -->
            <Button
                android:id="@+id/btn_batch_register"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:background="@drawable/button_green"
                android:gravity="center"
                android:text="批量注册"
                android:textColor="@color/white"
                android:textSize="17sp"
                android:textStyle="bold" />


        </LinearLayout>

        <!-- 底部空白 -->
        <View
            android:layout_width="match_parent"
            android:layout_height="40dp" />

    </LinearLayout>

</ScrollView>
