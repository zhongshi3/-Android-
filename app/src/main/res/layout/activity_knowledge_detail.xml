<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:orientation="vertical"
    tools:context=".KnowledgeDetailActivity">

    <!-- 顶部导航栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/blue"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_revert"
            android:contentDescription="返回"
            app:tint="@android:color/white" />


        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="知识点详情"
            android:textColor="@android:color/white"
            android:textSize="20sp"
            android:gravity="center"
            android:layout_marginEnd="40dp" />
    </LinearLayout>

    <!-- 滚动内容区 -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- 知识点名称 -->
            <TextView
                android:id="@+id/tv_detail_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="知识点名称"
                android:textColor="@color/blue"
                android:textSize="24sp"
                android:textStyle="bold" />

            <!-- 知识点类型 -->
            <TextView
                android:id="@+id/tv_detail_type"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/bg_tag_purple"
                android:paddingHorizontal="12dp"
                android:paddingVertical="4dp"
                android:text="知识点"
                android:textColor="@android:color/white"
                android:textSize="14sp" />

            <!-- 所属章、节信息 -->
            <TextView
                android:id="@+id/tv_detail_chapter"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="所属章节：第1章 > 1.1 节"
                android:textColor="@color/gray"
                android:textSize="14sp" />

            <!-- 前置知识点标题 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="前置知识点"
                android:textColor="@color/dark_gray"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- 前置知识点列表 -->
            <LinearLayout
                android:id="@+id/layout_prerequisites"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="vertical">
                <!-- 动态添加的知识点项 -->
            </LinearLayout>

            <!-- 知识点说明标题 -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="知识点说明"
                android:textColor="@color/dark_gray"
                android:textSize="16sp"
                android:textStyle="bold" />

            <!-- 知识点说明内容 -->
            <TextView
                android:id="@+id/tv_detail_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@android:color/white"
                android:padding="16dp"
                android:lineSpacingExtra="4dp"
                android:text="正在获取知识点说明..."
                android:textColor="@color/gray"
                android:textSize="15sp" />

            <!-- 加载进度条 -->
            <ProgressBar
                android:id="@+id/progress_description"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="20dp"
                android:indeterminateTint="@color/blue"
                android:visibility="gone" />

            <!-- 已学习按钮 -->
            <Button
                android:id="@+id/btn_mark_learned"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="16dp"
                android:text="标记为已学习"
                android:textSize="16sp"
                android:backgroundTint="@color/blue" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
