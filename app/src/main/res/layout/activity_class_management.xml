<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/class_management"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white"
    android:orientation="vertical"
    android:paddingHorizontal="30dp"
    tools:context=".ClassManagementActivity">

    <!-- 顶部区域：自定义箭头返回按钮 + 居中标题 -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:layout_marginBottom="30dp">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_revert"
            android:contentDescription="返回"
            app:tint="@color/blue" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="班级管理"
            android:textColor="@color/blue"
            android:textSize="28sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <!-- 班级统计按钮 -->
    <Button
        android:id="@+id/btn_class_statistics"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_marginBottom="30dp"
        android:background="@drawable/btn_main_bg"
        android:text="班级统计"
        android:textColor="@android:color/white"
        android:textSize="30sp" />


    <!-- 学生注册按钮 -->
    <Button
        android:id="@+id/btn_student_register"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:layout_marginBottom="30dp"
        android:background="@drawable/btn_main_bg"
        android:text="学生注册"
        android:textColor="@android:color/white"
        android:textSize="30sp" />

    <!-- 新建班级按钮 -->
    <Button
        android:id="@+id/btn_create_class"
        android:layout_width="match_parent"
        android:layout_height="70dp"
        android:background="@drawable/btn_main_bg"
        android:text="新建班级"
        android:textColor="@android:color/white"
        android:textSize="30sp" />

</LinearLayout>
