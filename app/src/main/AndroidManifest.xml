            android:exported="false" />
        <activity
            android:name=".TeacherRegisterActivity"
            android:label="教师注册"
            android:exported="false" />
        <activity
            android:name=".TeacherMainActivity"
            android:label="教师工作台"
            android:exported="false" />
        <activity
            android:name=".UserProfileActivity"
            android:label="用户信息"
            android:exported="false" />
        
        <!-- 班级管理相关Activity -->
        <activity
            android:name=".ClassManagementActivity"
            android:label="班级管理"
            android:exported="false" />

        <activity
            android:name=".ClassStatsDetailActivity"
